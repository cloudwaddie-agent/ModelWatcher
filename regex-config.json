{
  "$schema": "./regex-config.schema.json",
  "pages": [
    {
      "name": "Google Gemini - Gemini Models",
      "url": "https://gemini.google.com/",
      "patterns": ["gemini-[0-9.]+"]
    },
    {
      "name": "ChatGPT - Model Names",
      "url": "https://chatgpt.com/",
      "patterns": ["gpt-[0-9.]+"]
    },
    {
      "name": "Claude - Model Names",
      "url": "https://claude.ai/",
      "patterns": ["claude-[a-z]+-[0-9.]+"]
    },
    {
      "name": "Grok - xAI Models",
      "url": "https://grok.com",
      "patterns": ["grok-[0-9.]+"]
    }
  ],
  "webhook": {
    "webhookEnv": "REGEX_WEBHOOK",
    "url": "https://github.com/CloudWaddie/ModelWatcher"
  },
  "settings": {
    "timeout": 60000,
    "delay": 2500
  }
}
