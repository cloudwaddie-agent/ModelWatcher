{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Regex Monitoring Configuration",
  "type": "object",
  "required": ["pages"],
  "properties": {
    "pages": {
      "type": "array",
      "description": "List of pages to monitor for regex patterns",
      "items": {
        "type": "object",
        "required": ["name", "url", "patterns"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name for the page"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL to monitor"
          },
          "patterns": {
            "type": "array",
            "description": "Regex patterns to match on response body",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      }
    },
    "webhook": {
      "type": "object",
      "properties": {
        "webhookEnv": {
          "type": "string",
          "default": "REGEX_WEBHOOK",
          "description": "Environment variable name containing the webhook URL"
        },
        "url": {
          "type": "string",
          "description": "URL to show in embeds (e.g., GitHub repo)"
        }
      }
    },
    "settings": {
      "type": "object",
      "properties": {
        "timeout": {
          "type": "number",
          "default": 60000,
          "description": "Page load timeout in milliseconds"
        },
        "delay": {
          "type": "number",
          "default": 2500,
          "description": "Delay between URL checks in milliseconds"
        },
        "batchSize": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of concurrent URLs to check"
        }
      }
    }
  }
}
